# 实例配置（由 setup.sh 生成，或手动填写）
# scan-config.yaml 是给 agent 的搜集配置，本文件是给脚本的运行配置

INSTANCE_NAME="{{INSTANCE_NAME}}"
REPORT_DIR="{{REPORT_DIR}}"
AGENT_NAME="tech-radar"

# 超时时间（秒）
TIMEOUT_DAILY=2400    # 40 分钟
TIMEOUT_WEEKLY=2400   # 40 分钟
TIMEOUT_MONTHLY=3600  # 60 分钟

# ── 模型配置 ──────────────────────────────────────────────────
# 请根据你的平台填写正确的模型标识符（必填，留空会导致脚本报错）。
#
# 各平台示例（仅供参考，请替换为你实际可用的模型）：
#
#   Claude Code:
#     sonnet / opus / haiku          （Claude Code 别名）
#
#   OpenCode:                        （provider/model-id 格式）
#     mify-zhipu/zhipuai/glm-5.2
#     mify-openai/ppio/pa/gpt-5.5
#
#   Kiro-CLI:
#     claude-sonnet-4.6
#     claude-opus-4.6
#
# 建议日报用快速模型（成本低、速度快），周报/月报用更强模型（推理能力更好）。
MODEL_DAILY="sonnet"
MODEL_WEEKLY="opus"
MODEL_MONTHLY="opus"
