# Instance configuration (generated by setup.sh, or fill in manually)
# 实例配置（由 setup.sh 生成，或手动填写）
# scan-config.yaml is the collection config for the agent; this file is the runtime config for scripts.
# scan-config.yaml 是给 agent 的搜集配置，本文件是给脚本的运行配置。

INSTANCE_NAME="{{INSTANCE_NAME}}"
REPORT_DIR="{{REPORT_DIR}}"
AGENT_NAME="tech-radar"

# Timeout in seconds / 超时时间（秒）
TIMEOUT_DAILY=2400    # 40 minutes / 40 分钟
TIMEOUT_WEEKLY=2400   # 40 minutes / 40 分钟
TIMEOUT_MONTHLY=3600  # 60 minutes (monthly analysis is more complex) / 60 分钟（月报分析更复杂）

# ── Model Configuration / 模型配置 ─────────────────────────
# Fill in the correct model identifier for your platform (required, empty value will cause script errors).
# 请根据你的平台填写正确的模型标识符（必填，留空会导致脚本报错）。
#
# Examples per platform (for reference only, replace with your actual available models):
# 各平台示例（仅供参考，请替换为你实际可用的模型）：
#
#   Claude Code:
#     sonnet / opus / haiku          (Claude Code aliases)
#
#   OpenCode:                        (provider/model-id format)
#     mify-zhipu/zhipuai/glm-5.2
#     mify-openai/ppio/pa/gpt-5.5
#
#   Kiro-CLI:
#     claude-sonnet-4.6
#     claude-opus-4.6
#
# Recommendation: use a fast model for daily (lower cost, faster), a stronger model for weekly/monthly (better reasoning).
# 建议：日报用快速模型（成本低、速度快），周报/月报用更强模型（推理能力更好）。
MODEL_DAILY="sonnet"
MODEL_WEEKLY="opus"
MODEL_MONTHLY="opus"
